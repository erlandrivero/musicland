## 3. MongoDB Model (`models/PromptHistory.ts`)

```typescript
import mongoose, { Schema, Document } from 'mongoose';

export interface IPromptHistory extends Document {
  userId: string;
  artist: string;
  song: string;
  artistAnalysis: string;
  songAnalysis: string;
  prompts: Array<{
    title: string;
    prompt: string;
    characters: number;
  }>;
  modelUsed: string;
  createdAt: Date;
}

const PromptHistorySchema = new Schema({
  userId: { type: String, required: true, index: true },
  artist: { type: String, required: true },
  song: { type: String, required: true },
  artistAnalysis: { type: String },
  songAnalysis: { type: String },
  prompts: [{
    title: String,
    prompt: String,
    characters: Number
  }],
  modelUsed: { type: String, default: 'gemini-2.5-flash-search' },
  createdAt: { type: Date, default: Date.now }
});

export default mongoose.models.PromptHistory || mongoose.model<IPromptHistory>('PromptHistory', PromptHistorySchema);
```

